{
  "manifest_version": 3,
  "name": "AI Cheat Sheet Generator",
  "version": "1.1.0",
  "description": "Instantly turn GPT chats, text, and PDFs into beautiful, exam-ready cheat sheets with AI.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "host_permissions": [
    "http://18.189.87.197:8000/*", 
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ]
}

