# Copy to .env and fill in real values (.env is git-ignored).
#
# Docker Compose injects REDIS_HOST, PDF_GENERATION_HOST, etc.;
# the defaults below are for running uvicorn directly on your host.

MONGODB_URI=
DB_NAME=cheat_sheet_db
COLLECTION_NAME=knowledge_base

GOOGLE_API_KEY=
OPENAI_API_KEY=

# Non-Docker local: localhost; Docker Compose overrides to "redis"
REDIS_HOST=localhost
REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-2
S3_BUCKET_NAME=cheat-sheets

# Non-Docker: http://localhost:8000; Docker Compose: overridden to http://backend:8000
PDF_GENERATION_HOST=http://localhost:8000

RAG_RETRY_ATTEMPTS=6
RAG_RETRY_DELAY_SECONDS=2

# Embedding sub-batching (rate-limit avoidance)
EMBEDDING_BATCH_SIZE=100
EMBEDDING_BATCH_DELAY_SECONDS=0.5

# Ingestion quota (chunks)
MAX_CHUNKS_PER_USER=500
MAX_CHUNKS_PER_INGEST=200
